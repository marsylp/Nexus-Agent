# ═══════════════════════════════════════════════════
# Nexus Agent 密钥配置模板
# ═══════════════════════════════════════════════════
# 复制本文件为 .env.local，填入你的 API Key
# .env.local 不会提交到 Git
#
# 填入任意一个即可使用

# ── 国际 ──
# OPENAI_API_KEY=sk-xxx
# ANTHROPIC_API_KEY=sk-ant-xxx
# GOOGLE_API_KEY=AIza-xxx
# GROQ_API_KEY=gsk_xxx
# MISTRAL_API_KEY=xxx
# XAI_API_KEY=xai-xxx
# COHERE_API_KEY=xxx

# ── 国内 ──
# DEEPSEEK_API_KEY=sk-xxx
# ZHIPU_API_KEY=xxx
# QWEN_API_KEY=sk-xxx
# DOUBAO_API_KEY=xxx
# MOONSHOT_API_KEY=sk-xxx
# BAICHUAN_API_KEY=xxx
# MINIMAX_API_KEY=xxx
# STEPFUN_API_KEY=xxx
# YI_API_KEY=xxx

# ── 聚合平台 ──
# SILICON_API_KEY=sk-xxx
# OPENROUTER_API_KEY=sk-or-xxx
# TOGETHER_API_KEY=xxx

# ── 本地 Ollama（无需 Key） ──
# DISABLE_OLLAMA=0
# OLLAMA_MODEL=qwen2.5:7b
