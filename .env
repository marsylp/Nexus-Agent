# ═══════════════════════════════════════════════════
# Nexus Agent 配置文件（可提交到 Git）
# ═══════════════════════════════════════════════════
# 敏感数据（API Key）请放在 .env.local 中
# .env.local 不会提交到 Git，优先级高于本文件

# ── 模型选择模式 ───────────────────────────────────
# auto     — 智能路由，简单任务用轻量模型，复杂任务用强模型
# 固定模式 — deepseek, zhipu, silicon, openai, ollama, custom
# 运行时可通过 /model 命令切换
MODEL_MODE=auto

# ── Token 优化配置 ─────────────────────────────────
MAX_CONTEXT_TOKENS=4000
MAX_TOOL_RESULT_CHARS=1000
SHORT_TERM_TURNS=4

# ── 流式输出保护 ───────────────────────────────────
MAX_STREAM_OUTPUT_CHARS=8000
STREAM_TIMEOUT=120

# ── 工具审批配置 ───────────────────────────────────
# 空值=所有写操作需确认  工具名=指定放行  *=全部放行
AUTO_APPROVE=

# ── 错误恢复配置 ───────────────────────────────────
MAX_RETRIES=3
RETRY_BASE_DELAY=1.0
RETRY_STRATEGY=exponential

# ── Ollama 本地模型 ────────────────────────────────
# 未安装 Ollama 时保持 DISABLE_OLLAMA=1 跳过端口探测
# 安装后改为 0，并设置 OLLAMA_MODEL 为你拉取的模型名
DISABLE_OLLAMA=1
OLLAMA_MODEL=qwen2.5:7b

# ── 自定义兼容接口（MODEL_MODE=custom 时生效）─────
# CUSTOM_BASE_URL=https://your-api/v1
# CUSTOM_MODEL=your-model

# ── Agency Agents 专家角色库 ──────────────────────
# 指向 agency-agents 仓库的本地路径
# 不设置时自动搜索 ./agency-agents 和 ~/agency-agents
# AGENCY_AGENTS_DIR=/path/to/agency-agents
